# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — NEVER commit real values.
#
#   cp terraform.tfvars.example terraform.tfvars
#   vi terraform.tfvars

aws_region   = "us-east-1"
project_name = "vpc-bastion-honeypot"
environment  = "dev"

# Restrict SSH access to your IP only. Find your public IP at
# https://whatismyipaddress.com and append /32. Example:
#   allowed_ssh_cidr = "203.0.113.5/32"
#
# Leaving this as 0.0.0.0/0 exposes your bastion SSH port to the whole internet.
allowed_ssh_cidr = "0.0.0.0/0"

# Name of an existing EC2 key pair in the target region.
# Create one with: aws ec2 create-key-pair --key-name my-key --query 'KeyMaterial' --output text > ~/.ssh/my-key.pem
key_pair_name = "REPLACE_WITH_YOUR_KEY_PAIR_NAME"

# Email address subscribed to the security-alerts SNS topic.
# You'll receive a confirmation email from AWS — click the link to activate.
alert_email = "REPLACE_WITH_YOUR_EMAIL@example.com"
